# Copy to .env.local and fill in. NEXT_PUBLIC_* values are exposed to the
# browser (safe: anon key + VAPID public key only). Never put the service-role
# key or any S3 secret here — those live in Supabase Edge Function secrets.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key...

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BId...public_key...

# Optional: a vector map style URL (MapTiler/Protomaps) for crisper tiles.
# Leave unset to use free OpenStreetMap raster tiles (no key, no billing).
# NEXT_PUBLIC_MAP_STYLE=https://api.maptiler.com/maps/streets/style.json?key=YOUR_KEY
